# Copy to `.env` in this directory (`incubator/code-crawler`) and adjust values.
# Defaults are defined in `src/utils/env.utils.ts` (search for `DEFAULT_*`).

# -----------------------------------------------------------------------------
# CODE_CRAWLER_ROOT — parent directory of Git repositories (required for MCP /
# workspace tools when you rely on the default parent instead of passing rootDir).
# Example: absolute path, or use ~ for home.
# Default: unset (tools return a configuration error until set).
# -----------------------------------------------------------------------------
# CODE_CRAWLER_ROOT=/absolute/path/to/parent-of-git-repos

# -----------------------------------------------------------------------------
# CODE_CRAWLER_HOST — HTTP bind address.
# Default: 127.0.0.1
# -----------------------------------------------------------------------------
# CODE_CRAWLER_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# CODE_CRAWLER_PORT — HTTP listen port (1–65535). If unset/invalid, PORT is used.
# PORT — generic fallback used by many hosts (e.g. PaaS) when CODE_CRAWLER_PORT is unset.
# Default port: 3333
# -----------------------------------------------------------------------------
# CODE_CRAWLER_PORT=3333
# PORT=3333

# -----------------------------------------------------------------------------
# CODE_CRAWLER_CORS_ORIGIN — CORS `origin` value. If unset/blank, origin is `true`
# (reflect the request Origin; convenient for local SPA against this API).
# Set to a single origin string in production if you need to restrict browsers.
# -----------------------------------------------------------------------------
# CODE_CRAWLER_CORS_ORIGIN=http://127.0.0.1:3333

# -----------------------------------------------------------------------------
# CODE_CRAWLER_EMBEDDING_MODEL — Transformers.js model id for feature-extraction.
# First run may download weights to the Hugging Face / Transformers cache.
# Default: jinaai/jina-embeddings-v2-base-code
# Example (smaller code model): Xenova/all-MiniLM-L6-v2
# -----------------------------------------------------------------------------
# CODE_CRAWLER_EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code

# -----------------------------------------------------------------------------
# CODE_CRAWLER_EMBEDDING_DIM — Vector dimension for sqlite-vec; must match the model output.
# If unset, the default dimension in env.utils.ts applies (must stay in sync with the default model).
# If set to a non-positive integer, startup throws.
# -----------------------------------------------------------------------------
# CODE_CRAWLER_EMBEDDING_DIM=768

# -----------------------------------------------------------------------------
# CODE_CRAWLER_SEMANTIC_INDEX_DB_PATH — absolute or relative path to the SQLite index file.
# If unset/blank: ~/code-crawler/code-crawler-db (default basename in src/utils/env.utils.ts).
# -----------------------------------------------------------------------------
# CODE_CRAWLER_SEMANTIC_INDEX_DB_PATH=/path/to/code-crawler.sqlite

# -----------------------------------------------------------------------------
# CODE_CRAWLER_MAX_INDEX_FILE_BYTES — max file size (bytes) indexed per source file.
# Invalid or non-positive values fall back to the default (1 MiB).
# -----------------------------------------------------------------------------
# CODE_CRAWLER_MAX_INDEX_FILE_BYTES=1048576

# -----------------------------------------------------------------------------
# Chunking (semantic indexing): UTF-8 byte cap per chunk, max lines per chunk, overlap lines.
# Invalid or non-positive values fall back to defaults in env.utils.ts.
# -----------------------------------------------------------------------------
# CODE_CRAWLER_CHUNK_MAX_CHARS=1280
# CODE_CRAWLER_CHUNK_MAX_LINES=48
# CODE_CRAWLER_CHUNK_OVERLAP_LINES=10
