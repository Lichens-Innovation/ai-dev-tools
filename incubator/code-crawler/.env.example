# Copy to `.env`. All variables are required (non-empty) except CORS: unset or blank = mirror request Origin; see `src/utils/env.utils.ts`.

# Parent directory of Git repos (may use `~/...`; expanded like a shell).
CODE_CRAWLER_ROOT=~/git

# HTTP server — bind address and port.
CODE_CRAWLER_HOST=127.0.0.1
CODE_CRAWLER_PORT=3333

# CORS `origin`: leave empty to mirror the request Origin; otherwise set a fixed origin URL.
CODE_CRAWLER_CORS_ORIGIN=

# Embeddings — Transformers.js model id and vector dimension (must match the model output).
CODE_CRAWLER_EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code
CODE_CRAWLER_EMBEDDING_DIM=768

# Reranker — Transformers.js model id and dtype (`q8` or `fp32`).
CODE_CRAWLER_RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual
CODE_CRAWLER_RERANKER_DTYPE=q8

# RAG — Transformers.js text-generation model id.
CODE_CRAWLER_RAG_TEXT_MODEL=onnx-community/Qwen2.5-Coder-1.5B-Instruct

# Parent directory of Hub-style model folders (e.g. jinaai/jina-embeddings-v2-base-code/); `~/...` expanded; see `yarn download:models:xyz`.
CODE_CRAWLER_TRANSFORMERS_MODELS_PATH=~/code-crawler/models

# Max chunk texts per embedding forward pass (lower if the model OOMs, e.g. 16–32).
CODE_CRAWLER_EMBED_BATCH_SIZE=64

# Semantic index SQLite path (file or directory path; `~/...` expanded; resolved to absolute).
CODE_CRAWLER_SEMANTIC_INDEX_DB_PATH=~/code-crawler/code-crawler-db

# Max indexed file size in bytes.
CODE_CRAWLER_MAX_INDEX_FILE_BYTES=1048576

# Semantic chunking — max UTF-8 bytes per embedding payload (AST chunk + graph header + path/repo).
CODE_CRAWLER_CHUNK_MAX_CHARS=1280
