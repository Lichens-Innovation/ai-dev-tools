{
  "name": "code-crawler",
  "description": "A MCP server to crawl code repositories and extract information about the codebase.",
  "version": "0.0.1",
  "author": "Lichens Innovation",
  "repository": "https://github.com/lichens-innovation/ai-dev-tools",
  "private": true,
  "bin": {
    "code-crawler": "./dist/main.js"
  },
  "scripts": {
    "prepare": "node ./scripts/husky-install.mjs",
    "start": "CODE_CRAWLER_ROOT=\"$HOME/git/lichens\" CODE_CRAWLER_EMBEDDING_MODEL=\"jinaai/jina-embeddings-v2-base-code\" nest start --watch",
    "start:prod": "node dist/main.js",
    "inspector": "npx @modelcontextprotocol/inspector --transport http --server-url http://127.0.0.1:3333/mcp",
    "generate:version": "tsx ./scripts/generate-version.ts",
    "download:models": "tsx ./scripts/models-download.ts jinaai/jina-embeddings-v2-base-code",
    "build": "nest build",
    "lint": "eslint . && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format:fix": "prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@lichens-innovation/ts-common": "^1.15.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/serve-static": "^5.0.5",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "http-status-codes": "^2.3.0",
    "nestjs-zod": "^5.3.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@huggingface/hub": "^2.11.0",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@nestjs/cli": "^11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5",
    "@types/node": "^25.6.0",
    "commander": "^14.0.3",
    "commitlint": "^20.5.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
