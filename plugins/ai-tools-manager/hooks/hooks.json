{
  "hooks": {
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/inject-agent-skills.js"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/afk-session-log.js"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/afk-session-cleanup.sh"]
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "create-skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/gather-info.sh", "create-skill"]
          }
        ]
      },
      {
        "matcher": "create-subagent",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/gather-info.sh", "create-subagent"]
          }
        ]
      },
      {
        "matcher": "create-plugin",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/gather-info.sh", "create-plugin"]
          }
        ]
      },
      {
        "matcher": "create-marketplace",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/gather-info.sh", "create-marketplace"]
          }
        ]
      },
      {
        "matcher": "agents-framework-kickstarter",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/gather-info.sh", "agents-framework-kickstarter"]
          }
        ]
      }
    ]
  }
}
