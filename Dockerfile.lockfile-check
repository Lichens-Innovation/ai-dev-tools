FROM node:24-alpine

RUN corepack enable

WORKDIR /app

# Copy root manifests
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy workspace package.json files so pnpm can resolve the workspaces
COPY apps/help-server/package.json ./apps/help-server/
COPY apps/ai-tools-manager/package.json ./apps/ai-tools-manager/
COPY packages/ui/package.json ./packages/ui/
COPY packages/tailwind-config/package.json ./packages/tailwind-config/
COPY packages/eslint-config/package.json ./packages/eslint-config/
COPY packages/typescript-config/package.json ./packages/typescript-config/
COPY packages/claude-fs/package.json ./packages/claude-fs/

# --frozen-lockfile fails if pnpm-lock.yaml is out of date with the manifest
RUN pnpm install --frozen-lockfile \
    && echo "✓ pnpm-lock.yaml is up to date — no changes" \
    || (echo "pnpm-lock.yaml is out of date - run pnpm install and commit the result" && exit 1)
